# 飞书应用凭证
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 飞书域名: feishu (国内) 或 larksuite (海外)
FEISHU_DOMAIN=feishu

# 数据目录
DATA_DIR=./data

# 每用户独立工作目录根路径，支持 ~
PI_WORKSPACE_ROOT=~/code/pi-workspace

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 流式回复
STREAMING_ENABLED=true

# 飞书单条消息文本上限（字符数）
TEXT_CHUNK_LIMIT=2000
