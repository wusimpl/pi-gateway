# 飞书应用凭证
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 飞书域名: feishu (国内) 或 larksuite (海外)
FEISHU_DOMAIN=feishu

# 群聊策略: disabled | allowlist | open
FEISHU_GROUP_CHAT_POLICY=disabled
# allowlist 模式下允许响应的群 chat_id，多个用逗号分隔
FEISHU_GROUP_CHAT_ALLOWLIST=
# 群消息接收模式: mention | all | keyword
FEISHU_GROUP_MESSAGE_MODE=mention
# keyword 模式下命中的关键词，多个用空白分隔
FEISHU_GROUP_MESSAGE_KEYWORDS=
# 可选：机器人 open_id；填写后 mention 模式会精确判断是否 @ 机器人
FEISHU_BOT_OPEN_ID=
# 群聊 owner open_id，多个用逗号分隔
FEISHU_OWNER_OPEN_IDS=

# 数据目录
DATA_DIR=./data

# 每用户独立工作目录根路径，支持 ~
PI_WORKSPACE_ROOT=~/code/pi-workspace

# 是否禁用全局 ~/.pi/agent/AGENTS.md / CLAUDE.md，只保留项目内规则文件
PI_DISABLE_GLOBAL_AGENTS=false
# 飞书网关专属全局规则文件；仅 pi-gateway 会加载，普通 pi code agent 不受影响
PI_GATEWAY_AGENTS_FILE=~/.pi/feishu-gateway/AGENTS.md

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 流式回复
STREAMING_ENABLED=false

# 在回复里显示最近的工具调用
PI_SHOW_TOOL_CALLS_IN_REPLY=true

# 飞书单条消息文本上限（字符数）
TEXT_CHUNK_LIMIT=2000

# 处理中 reaction 的 emoji_type；留空或填错都会自动禁用，例如 SMILE
FEISHU_PROCESSING_REACTION_TYPE=SMILE

# 语音转写 provider: whisper | sensevoice | doubao
FEISHU_AUDIO_TRANSCRIBE_PROVIDER=whisper
# whisper 外部转写脚本路径，支持 ~
FEISHU_AUDIO_TRANSCRIBE_SCRIPT=~/.openclaw/skills/audio-transcribe/transcribe.sh
# 语音识别语言
FEISHU_AUDIO_TRANSCRIBE_LANGUAGE=zh
# SenseVoice Python 路径，支持 ~
FEISHU_AUDIO_TRANSCRIBE_SENSEVOICE_PYTHON=python3
# SenseVoice 模型名或模型路径，支持 ~
FEISHU_AUDIO_TRANSCRIBE_SENSEVOICE_MODEL=iic/SenseVoiceSmall
# SenseVoice 运行设备
FEISHU_AUDIO_TRANSCRIBE_SENSEVOICE_DEVICE=cpu
# 豆包录音文件极速版识别 API Key
FEISHU_AUDIO_TRANSCRIBE_DOUBAO_API_KEY=
